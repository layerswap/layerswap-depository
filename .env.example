# Deployer private key (never commit the real .env)
PRIVATE_KEY=0xabc...

# Owner address (set to your Gnosis Safe on mainnet)
OWNER_ADDRESS=0x...

# Comma-separated initial whitelist (optional)
WHITELISTED_ADDRESSES=0x...,0x...

# RPC endpoints (used for deployment, not verification)
RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Verification (used by script/VerifyAllFromBroadcast.ps1) ──────────────────

# Etherscan unified API key (works across all Etherscan-family explorers)
ETHERSCAN_API_KEY=

# Deployed contract address to verify
CONTRACT_ADDRESS=0x...

# ABI-encoded constructor args (hex string)
# Generate with: cast abi-encode "constructor(address,address[])" 0xOwner "[0xAddr1,0xAddr2]"
CONSTRUCTOR_ARGS=0x...

# Comma-separated list of networks to verify on (names or chain IDs both work)
# Full list of 68 Etherscan V2 supported networks:
#   mainnet, sepolia, hoodi, holesky, arbitrum, arbitrum-sepolia, optimism, optimism-sepolia,
#   base, base-sepolia, polygon, polygon-amoy, bsc, bsc-testnet, avalanche, avalanche-fuji,
#   linea, linea-sepolia, blast, blast-sepolia, scroll, scroll-sepolia, mantle, mantle-sepolia,
#   gnosis, celo, celo-sepolia, fraxtal, fraxtal-testnet, moonbeam, moonriver, moonbase-alpha,
#   taiko, taiko-hoodi, bttc, bttc-testnet, opbnb-mainnet, opbnb-testnet, xdc-mainnet, xdc-testnet,
#   world, world-sepolia, sonic, sonic-testnet, unichain, unichain-sepolia, abstract, abstract-testnet,
#   berachain, berachain-bepolia, swellchain, swellchain-testnet, monad, monad-testnet, hyperliquid,
#   apechain, apechain-curtis, sei, sei-testnet, katana, katana-bokuto, memecore, memecore-testnet,
#   megaeth, megaeth-testnet, stable-mainnet, stable-testnet, plasma, plasma-testnet, mode, zora
VERIFY_CHAINS=sepolia

